# Database Configuration
DATABASE_URL=postgresql+asyncpg://vita:your_password_here@localhost:5433/vita_db
DB_PASSWORD=your_password_here

# Redis Configuration
REDIS_URL=redis://localhost:6380

# MQTT Configuration
MQTT_BROKER=104.131.36.215
MQTT_PORT=1883
MQTT_USER=vita_backend
MQTT_PASS=your_mqtt_password_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_at_least_32_characters_long
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# FCM Configuration (Optional)
FCM_CREDENTIALS_PATH=/path/to/firebase-credentials.json

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "https://app.bgnius.com"]

# Application Configuration
DEBUG=true
API_VERSION=v1
API_PREFIX=/api/v1